    "import sys\n",
    "import subprocess\n",
    "import time\n",
    "import matplotlib.pyplot as plt\n",
    "from collections import defaultdict\n",
    "\n",
    "USE_SUBSAMPLE = False \n",
    "\n",
    "df = pd.read_csv('imdb_top_1000.csv')\n",
    "\n",
    "if USE_SUBSAMPLE:\n",
    "    df = df.head(500)\n",
    "    print(f\"Subsample mode: {len(df)} rows\")\n",
    "\n",
    "print(df.describe())\n",
    "\n",
    "\n",
    "\n",
    "star_cols = ['Star1', 'Star2', 'Star3', 'Star4']\n",
    "baskets = []\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    actors = [str(row[c]).strip() for c in star_cols if pd.notna(row[c])]\n",
    "    if actors:\n",
    "        baskets.append(actors)"
