    "def get_freq_1(baskets, min_count):\n",
    "    counts = defaultdict(int)\n",
    "    for b in baskets:\n",
    "        for item in b:\n",
    "            counts[frozenset([item])] += 1\n",
    "            \n",
    "    return {k: v for k, v in counts.items() if v >= min_count}\n",
    "\n",
    "def gen_candidates(freq_prev, k):\n",
    "    candidates = set()\n",
    "    prev_keys = list(freq_prev.keys())\n",
    "    \n",
    "    for i in range(len(prev_keys)):\n",
    "        for j in range(i + 1, len(prev_keys)):\n",
    "            
    "            union_set = prev_keys[i].union(prev_keys[j])\n",
    "            if len(union_set) == k:\n",
    "                candidates.add(union_set)\n",
    "    return candidates\n",
    "\n",
    "def filter_candidates(baskets, candidates, min_count):\n",
    "    counts = defaultdict(int)\n",
    "    for b in baskets:\n",
    "        basket_set = set(b)\n",
    "        for c in candidates:\n",
    "            if c.issubset(basket_set):\n",
    "                counts[c] += 1\n",
    "                \n",
    "    return {c: v for c, v in counts.items() if v >= min_count}\n",
    "\n",
    "def run_apriori(baskets, min_support):\n",
    "    min_count = len(baskets) * min_support\n",
    "    print(f\"Threshold absolute count: {min_count}\")\n",
    "    \n",
    "    all_freq = {}\n",
    "    \n",
    "    freq_k = get_freq_1(baskets, min_count)\n",
    "    all_freq.update(freq_k)\n",
    "    \n",
    "    k = 2\n",
    "    while freq_k:\n",
    "        candidates = gen_candidates(freq_k, k)\n",
    "        if not candidates:\n",
    "            break\n",
    "            \n",
    "        freq_k = filter_candidates(baskets, candidates, min_count)\n",
    "        if freq_k:\n",
    "            all_freq.update(freq_k)\n",
    "            k += 1\n",
    "            \n",
    "    return all_freq\n",
    "\n",
    "MIN_SUPPORT = 0.002\n",
    "freq_items = run_apriori(baskets, MIN_SUPPORT)\n",
    "\n",
    "print(f\"Total frequent itemsets found: {len(freq_items)}\")\n",
    "\n",
    "print(\"\\nTop 10 frequent combinations:\")\n",
    "top_items = sorted(freq_items.items(), key=lambda x: x[1], reverse=True)[:10]\n",
    "for itemset, count in top_items:\n",
    "    print(f\"{list(itemset)} : {count}\")"
   ]
  },
