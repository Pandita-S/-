    "ratios = [0.25, 0.5, 0.75, 1.0]\n",
    "exec_times = []\n",
    "\n",
    "print(\"Running scalability benchmark...\")\n",
    "\n",
    "for r in ratios:\n",
    "    size = int(len(baskets) * r)\n",
    "    subset = baskets[:size]\n",
    "    \n",
    "    t0 = time.time()\n",
    "    _ = run_apriori(subset, min_support=(2.0 / size)) \n",
    "    t1 = time.time()\n",
    "    \n",
    "    exec_times.append(t1 - t0)\n",
    "    print(f\"Size: {size} ({r*100:.0f}%) | Time: {t1 - t0:.4f}s\")\n",
    "\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "x_sizes = [int(len(baskets) * r) for r in ratios]\n",
    "plt.plot(x_sizes, exec_times, marker='o', color='#1f77b4', linewidth=2)\n",
    "\n",
    "plt.title('Scalability: Execution Time vs. Dataset Size')\n",
    "plt.xlabel('Number of Baskets')\n",
    "plt.ylabel('Execution Time (s)')\n",
    "plt.grid(True, linestyle='--', alpha=0.6)\n",
    "plt.show()"
   ]
