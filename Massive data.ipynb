    "def generate_rules(freq_items, total_baskets, min_conf=0.5):\n",
    "    rules = []\n",
    "    \n",
    "    for itemset, supp_count in freq_items.items():\n",
    "        if len(itemset) < 2:\n",
    "            continue\n",
    "            \n",
    "        for item in itemset:\n",
    "            cons = frozenset([item])\n",
    "            ant = itemset - cons\n",
    "            \n",
    "            supp_A = freq_items.get(ant, 0)\n",
    "            supp_B = freq_items.get(cons, 0)\n",
    "            \n",
    "            if supp_A > 0:\n",
    "                conf = supp_count / supp_A\n",
    "                supp_B_ratio = supp_B / total_baskets\n",
    "                lift = conf / supp_B_ratio if supp_B_ratio > 0 else 0\n",
    "                \n",
    "                if conf >= min_conf:\n",
    "                    rules.append({\n",
    "                        'A': list(ant),\n",
    "                        'B': list(cons),\n",
    "                        'conf': conf,\n",
    "                        'lift': lift,\n",
    "                        'supp': supp_count\n",
    "                    })\n",
    "                    \n",
    "    return rules\n",
    "\n",
    "MIN_CONF = 0.5\n",
    "rules = generate_rules(freq_items, len(baskets), MIN_CONF)\n",
    "\n",
    "print(f\"Rules generated (conf >= {MIN_CONF}): {len(rules)}\")\n",
    "\n",
    "top_rules = sorted(rules, key=lambda x: x['lift'], reverse=True)[:15]\n",
    "\n",
    "print(\"\\nTop 15 Association Rules by Lift:\")\n",
    "for r in top_rules:\n",
    "    print(f\"{r['A']} -> {r['B']} | Conf: {r['conf']:.2f} | Lift: {r['lift']:.2f} | Supp: {r['supp']}\")"
   ]
  },
